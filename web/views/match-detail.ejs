<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/assets/hub.css" />
</head>

<body class="hub-body">
    <%- include("partials/nav", { currentSection }) %>

    <% 
        const totalPlayers = match.player_stats_total_count || (match.players || []).length || 0;
        const resultTone = /vitt/i.test(match.result_label || "") ? "good" : /sconf/i.test(match.result_label || "") ? "bad" : "warn";
        const playerSections = [];
        const knownMapOrderIndexes = new Set();

        for (const map of match.maps || []) {
            const orderIndex = Number(map.order_index || 0);
            knownMapOrderIndexes.add(orderIndex);
            playerSections.push({
                orderIndex,
                map,
                players: (playersByMap.get(orderIndex) || []).slice(),
            });
        }

        for (const [orderIndexRaw, sectionPlayers] of playersByMap.entries()) {
            const orderIndex = Number(orderIndexRaw || 0);
            if (knownMapOrderIndexes.has(orderIndex)) continue;

            playerSections.push({
                orderIndex,
                map: {
                    order_index: orderIndex,
                    mode: "",
                    map_name: "",
                    side_name: "",
                    team1_score: null,
                    team2_score: null,
                },
                players: (sectionPlayers || []).slice(),
            });
        }

        playerSections.sort((a, b) => Number(a.orderIndex || 0) - Number(b.orderIndex || 0));
    %>

    <section class="hub-page-header">
        <div>
            <h1><%= match.team1 %> vs <%= match.team2 %></h1>
            <p>
                <% if (importedPlayers) { %>
                    Player del match importati nel DB dal file estratto. Ora puoi anche collegarli al roster dal pannello.
                <% } else if (match.player_stats_source === "export_file") { %>
                    Player e punteggi letti automaticamente dalle immagini. Considerali dati provvisori finché non li confermi.
                <% } else if (extractedPlayers) { %>
                    Player estratti dagli screenshot. Ora puoi collegarli al roster e il sistema ricorderà i nomi ripetuti.
                <% } else if (linkedPlayers) { %>
                    Collegamenti roster salvati correttamente. Alias automatici applicati: <%= autoLinked || 0 %>.
                <% } else if (reanalyzed) { %>
                    Immagini del match rianalizzate correttamente con il parser attuale.
                <% } else if (saved) { %>
                    Stato match aggiornato correttamente dal pannello.
                <% } else if (match.status === "cancelled") { %>
                    Scrim marcata come cancellata manualmente. La scheda resta consultabile ma non viene considerata un match attivo.
                <% } else if (match.status === "draft") { %>
                    Match creato dalla parte 1. La scheda è già visibile sul web e verrà completata quando pubblichi la parte 2.
                <% } else { %>
                    Match completato dal flusso Discord + web. Qui trovi risultato, mappe, screenshot e player estratti.
                <% } %>
            </p>
            <div class="hub-chip">
                <span class="hub-chip-dot"></span>
                Stato: <%= match.statusLabel.toLowerCase() %>
            </div>
        </div>
        <div class="hub-actions">
            <% if (match.player_stats_source === "export_file") { %>
                <form method="post" action="/matches/<%= match.slug %>/import-player-stats" style="display:inline;">
                    <button class="hub-button secondary" type="submit">Importa player nel DB</button>
                </form>
            <% } %>
            <form method="post" action="/matches/<%= match.slug %>/extract-players" style="display:inline;">
                <button class="hub-button secondary" type="submit">Estrai player da screenshot</button>
            </form>
            <form method="post" action="/matches/<%= match.slug %>/reanalyze" style="display:inline;">
                <button class="hub-button secondary" type="submit">Rianalizza immagini</button>
            </form>
            <% if (match.status === "cancelled") { %>
                <form method="post" action="/matches/<%= match.slug %>/status" style="display:inline;">
                    <input type="hidden" name="action" value="restore" />
                    <button class="hub-button secondary" type="submit">Ripristina stato automatico</button>
                </form>
            <% } else { %>
                <form method="post" action="/matches/<%= match.slug %>/status" style="display:inline;">
                    <input type="hidden" name="action" value="cancel" />
                    <button class="hub-button danger" type="submit">Segna scrim cancellata</button>
                </form>
            <% } %>
            <a class="hub-button secondary" href="/matches">Torna ai match</a>
            <a class="hub-button secondary" href="/dashboard">Dashboard</a>
        </div>
    </section>

    <section class="hub-card hub-result-hero">
        <div class="hub-result-hero-top">
            <div>
                <div class="hub-result-eyebrow">Risultato Scrim</div>
                <div class="hub-result-subline">
                    <span><%= match.matchDateLabel || "Data da definire" %></span>
                    <span><%= match.match_time || "Ora non disponibile" %></span>
                    <span><%= (match.maps || []).length %> mappe</span>
                    <span><%= totalPlayers %> player</span>
                </div>
            </div>
            <span class="hub-badge <%= resultTone %>">
                <%= match.result_label || "Risultato in attesa" %>
            </span>
        </div>
        <div class="hub-result-scoreboard">
            <article class="hub-result-team-card <%= match.winner_team === match.team1 ? 'winner' : '' %>">
                <div class="hub-result-team-name"><%= match.team1 %></div>
                <div class="hub-result-team-score"><%= match.team1_series_score ?? "-" %></div>
            </article>
            <div class="hub-result-score-separator">:</div>
            <article class="hub-result-team-card <%= match.winner_team === match.team2 ? 'winner' : '' %>">
                <div class="hub-result-team-name"><%= match.team2 %></div>
                <div class="hub-result-team-score"><%= match.team2_series_score ?? "-" %></div>
            </article>
        </div>
        <div class="hub-result-hero-bottom">
            <div class="hub-mini-pill active">Vincitore: <%= match.winner_team || "In attesa" %></div>
            <div class="hub-mini-pill">Review: <%= match.needs_review ? "manuale consigliata" : "allineata" %></div>
            <div class="hub-mini-pill">Sorgente player: <%= match.player_stats_source === "database" ? "DB" : match.player_stats_source === "export_file" ? "Provvisori da immagini" : "nessuna" %></div>
            <% if (match.player_stats_provisional || match.map_scores_provisional) { %>
                <div class="hub-mini-pill">Dati provvisori da immagini</div>
            <% } %>
        </div>
    </section>

    <section class="hub-summary-grid">
        <article class="hub-grid-card">
            <div class="hub-summary-label">Data</div>
            <div class="hub-summary-value" style="font-size:22px;"><%= match.matchDateLabel || "Da definire" %></div>
            <div class="hub-summary-sub"><%= match.match_time || "Ora non disponibile" %></div>
        </article>
        <article class="hub-grid-card">
            <div class="hub-summary-label">Serie</div>
            <div class="hub-summary-value"><%= match.team1_series_score ?? "-" %> - <%= match.team2_series_score ?? "-" %></div>
            <div class="hub-summary-sub"><%= match.result_label || "Risultato in attesa" %></div>
        </article>
        <article class="hub-grid-card">
            <div class="hub-summary-label">Vincitore</div>
            <div class="hub-summary-value" style="font-size:22px;"><%= match.winner_team || "In attesa" %></div>
            <div class="hub-summary-sub">Aggiornato dalla parte 2</div>
        </article>
        <article class="hub-grid-card">
            <div class="hub-summary-label">Review</div>
            <div class="hub-summary-value" style="font-size:22px;"><%= match.needs_review ? "SI" : "NO" %></div>
            <div class="hub-summary-sub"><%= match.needs_review ? "Controllo manuale consigliato" : "Dati allineati" %></div>
        </article>
        <article class="hub-grid-card">
            <div class="hub-summary-label">Player</div>
            <div class="hub-summary-value" style="font-size:22px;"><%= match.player_stats_total_count || (match.players || []).length || 0 %></div>
            <div class="hub-summary-sub">
                <% if (match.player_stats_source === "database") { %>
                    Caricati dal DB
                <% } else if (match.player_stats_source === "export_file") { %>
                    Provvisori da immagini
                <% } else { %>
                    Non ancora disponibili
                <% } %>
            </div>
        </article>
    </section>

    <section class="hub-card" style="margin-bottom:18px;">
        <div class="hub-table-head" style="padding:0 0 14px; border-bottom:none;">
            <div>
                <h2>Mappe</h2>
                <p>La parte 1 prepara la struttura delle mappe. Quando lo score arriva dalle immagini viene mostrato come provvisorio.</p>
            </div>
        </div>
        <div class="hub-match-map-grid">
            <% for (const map of match.maps) { %>
                <article class="hub-grid-card hub-match-map-card">
                    <div class="hub-match-map-top">
                        <div>
                            <div class="hub-summary-label">Mappa <%= map.order_index %></div>
                            <div class="hub-match-map-name"><%= map.map_name || "Mappa da definire" %></div>
                        </div>
                        <div style="display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end;">
                            <div class="hub-map-pill"><%= map.mode || "?" %></div>
                            <% if (map.score_source === "export_file") { %>
                                <div class="hub-badge warn">Provvisorio</div>
                            <% } %>
                        </div>
                    </div>
                    <div class="hub-match-map-side"><%= map.side_name || "Side non definito" %></div>
                    <div class="hub-match-map-score">
                        <span><%= map.team1_score ?? "-" %></span>
                        <span class="hub-match-map-score-separator">:</span>
                        <span><%= map.team2_score ?? "-" %></span>
                    </div>
                </article>
            <% } %>
        </div>
    </section>

    <section class="hub-card" style="margin-bottom:18px;">
        <div class="hub-table-head" style="padding:0 0 14px; border-bottom:none;">
            <div>
                <h2>Screenshot</h2>
                <p>Le immagini arrivano dalla parte 2 e aggiornano automaticamente questa scheda.</p>
            </div>
        </div>
        <% const screenshots = (match.assets || []).filter(asset => asset.asset_type === "screenshot"); %>
        <% if (!screenshots.length) { %>
            <div class="hub-muted">Nessuno screenshot ancora associato a questo match.</div>
        <% } else { %>
            <div class="hub-screenshot-list">
                <% for (const asset of screenshots) { %>
                    <a href="<%= asset.asset_url %>" target="_blank" rel="noreferrer" class="hub-grid-card hub-screenshot-card">
                        <div class="hub-screenshot-order">Screenshot <%= asset.sort_order || 0 %></div>
                        <img src="<%= asset.asset_url %>" alt="Screenshot match"
                            style="width:100%; height:220px; object-fit:cover; border-radius:14px; display:block;" loading="lazy" />
                    </a>
                <% } %>
            </div>
        <% } %>
    </section>

    <section class="hub-card hub-table-card">
        <div class="hub-table-head">
            <div>
                <h2>Player estratti</h2>
                <p>Qui puoi collegare ogni nome estratto a un player del roster. Gli alias salvati verranno riusati automaticamente sui nomi che si ripetono.</p>
            </div>
            <div class="hub-muted">
                Totale righe: <strong><%= totalPlayers %></strong>
            </div>
        </div>
        <% const playersImportedInDb = (match.players || []).some(player => player.id); %>
        <% if (match.player_stats_source === "export_file") { %>
            <div class="hub-notice" style="margin-bottom:16px;">
                Questi player arrivano dal file <code>exports/match-player-stats.json</code> e sono mostrati in sola lettura come dati <strong>provvisori</strong>. Usa <strong>Importa player nel DB</strong> per poterli collegare al roster dopo la verifica.
            </div>
        <% } %>
        <form method="post" action="/matches/<%= match.slug %>/players/link">
        <% if (!(match.players || []).length) { %>
            <div class="hub-muted">Nessun dato player ancora disponibile.</div>
        <% } %>
        <div class="hub-player-sections">
            <% for (const section of playerSections) { %>
                <% if (!(section.players || []).length) { continue; } %>
                <% 
                    const groupedPlayers = new Map();
                    for (const player of section.players || []) {
                        const teamName = String(player.team_name || "Team sconosciuto");
                        if (!groupedPlayers.has(teamName)) groupedPlayers.set(teamName, []);
                        groupedPlayers.get(teamName).push(player);
                    }
                    const teamGroups = Array.from(groupedPlayers.entries());
                %>
                <article class="hub-player-section">
                    <div class="hub-player-section-head">
                        <div>
                            <div class="hub-summary-label">Mappa <%= section.map.order_index || section.orderIndex || "-" %></div>
                            <div class="hub-player-section-title">
                                <%= section.map.mode || "Modalità ?" %> · <%= section.map.map_name || "Mappa da definire" %>
                            </div>
                            <div class="hub-member-sub"><%= section.map.side_name || "Side non definito" %></div>
                        </div>
                        <div class="hub-player-section-score">
                            <span><%= section.map.team1_score ?? "-" %></span>
                            <span class="hub-player-section-score-separator">:</span>
                            <span><%= section.map.team2_score ?? "-" %></span>
                        </div>
                    </div>
                    <div class="hub-player-team-grid">
                        <% for (const [teamName, teamPlayers] of teamGroups) { %>
                            <article class="hub-player-team-card">
                                <div class="hub-player-team-head">
                                    <div class="hub-player-team-name"><%= teamName || "Team sconosciuto" %></div>
                                    <div class="hub-mini-pill"><%= teamPlayers.length %> player</div>
                                </div>
                                <div class="hub-player-list">
                                    <% for (let index = 0; index < teamPlayers.length; index += 1) { %>
                                        <% const player = teamPlayers[index]; %>
                                        <div class="hub-player-row">
                                            <div class="hub-player-rank"><%= index + 1 %></div>
                                            <div class="hub-player-main">
                                                <div class="hub-player-name-line">
                                                    <strong><%= player.player_name || "-" %></strong>
                                                    <% if (player.is_mvp) { %>
                                                        <span class="hub-player-mvp">MVP</span>
                                                    <% } %>
                                                </div>
                                                <% if (player.resolved_player_name) { %>
                                                    <div class="hub-member-sub">Risolto: <%= player.resolved_player_name %></div>
                                                <% } %>
                                                <div class="hub-player-metrics">
                                                    <span class="hub-mini-pill">Punti <strong><%= player.points ?? "-" %></strong></span>
                                                    <span class="hub-mini-pill">K/D/A <strong><%= player.kills ?? "-" %> / <%= player.deaths ?? "-" %> / <%= player.assists ?? "-" %></strong></span>
                                                    <span class="hub-mini-pill">Tempo <strong><%= player.time_played || "-" %></strong></span>
                                                    <span class="hub-mini-pill">Impatto <strong><%= player.impact ?? "-" %></strong></span>
                                                </div>
                                            </div>
                                            <div class="hub-player-roster-cell">
                                                <% if (player.id) { %>
                                                    <select class="hub-input" name="links[<%= player.id %>]">
                                                        <option value="">Non collegato</option>
                                                        <% for (const member of roster || []) { %>
                                                            <option value="<%= member.id %>" <%= String(player.member_id || "") === String(member.id) ? "selected" : "" %>>
                                                                <%= member.label %><% if (member.discordLabel && member.discordLabel !== member.label) { %> | <%= member.discordLabel %><% } %>
                                                            </option>
                                                        <% } %>
                                                    </select>
                                                <% } else { %>
                                                    <span class="hub-muted">Importa nel DB</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            </article>
                        <% } %>
                    </div>
                </article>
            <% } %>
        </div>
        <% if ((match.players || []).length && playersImportedInDb) { %>
            <div class="hub-actions" style="margin-top:16px;">
                <button class="hub-button" type="submit">Salva collegamenti roster</button>
            </div>
        <% } %>
        </form>
    </section>

    <section class="hub-card" style="margin-bottom:18px;">
        <div class="hub-table-head" style="padding:0 0 14px; border-bottom:none;">
            <div>
                <h2>Debug Parser JSON</h2>
                <p>Output grezzo salvato dal parser immagini per questo match.</p>
            </div>
        </div>
        <% if (!match.analysis_debug_json) { %>
            <div class="hub-muted">Nessun debug parser salvato ancora per questo match.</div>
        <% } else { %>
            <pre style="margin:0; padding:16px; border-radius:16px; overflow:auto; background:#07130d; color:#d9f7e6; border:1px solid rgba(67, 160, 92, 0.18); white-space:pre-wrap; word-break:break-word;"><%= match.analysis_debug_json %></pre>
        <% } %>
    </section>

    </main>
</div>
</body>

</html>
