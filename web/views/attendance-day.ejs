<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= pageTitle %>
    </title>
    <style>
        :root {
            --bg: #06070b;
            --bg-soft: #0d0f17;
            --card: #121521;
            --card-2: #171b2a;
            --line: rgba(170, 110, 255, 0.18);
            --line-strong: rgba(170, 110, 255, 0.35);
            --text: #eef2ff;
            --muted: #a7b0c9;
            --purple: #8b4dff;
            --purple-2: #5f23cb;
            --green: #7eea57;
            --green-dark: #4dc62b;
            --danger: #ff6b81;
            --warning: #ffd166;
            --shadow: 0 18px 60px rgba(0, 0, 0, 0.38);
            --radius: 20px;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            padding: 0;
            background:
                radial-gradient(circle at top, rgba(139, 77, 255, 0.22), transparent 30%),
                radial-gradient(circle at right, rgba(126, 234, 87, 0.08), transparent 20%),
                linear-gradient(180deg, #05060a 0%, #090b12 100%);
            color: var(--text);
            font-family: Arial, sans-serif;
        }

        body {
            min-height: 100vh;
            padding: 24px;
        }

        a {
            color: #d8c8ff;
            text-decoration: none;
        }

        a:hover {
            color: white;
        }

        .container {
            max-width: 1450px;
            margin: 0 auto;
        }

        .hero {
            position: relative;
            overflow: hidden;
            background:
                linear-gradient(135deg, rgba(139, 77, 255, 0.22), rgba(95, 35, 203, 0.16)),
                linear-gradient(180deg, rgba(18, 21, 33, 0.98), rgba(12, 14, 23, 0.98));
            border: 1px solid var(--line-strong);
            border-radius: 28px;
            padding: 26px;
            margin-bottom: 20px;
            box-shadow: var(--shadow);
        }

        .hero::after {
            content: "";
            position: absolute;
            inset: auto -80px -80px auto;
            width: 240px;
            height: 240px;
            background: radial-gradient(circle, rgba(126, 234, 87, 0.18), transparent 70%);
            pointer-events: none;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 110px 1fr auto;
            gap: 20px;
            align-items: center;
        }

        .logo-wrap {
            width: 118px;
            height: 118px;
            border-radius: 28px;
            background: linear-gradient(180deg, rgba(139, 77, 255, 0.20), rgba(95, 35, 203, 0.12));
            border: 1px solid rgba(167, 115, 255, 0.28);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: inset 0 0 30px rgba(139, 77, 255, 0.15);
        }

        .logo-wrap img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
            padding: 10px;
        }

        .eyebrow {
            color: var(--green);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .hero h1 {
            margin: 0 0 10px;
            font-size: 34px;
            line-height: 1.05;
        }

        .hero p {
            margin: 0;
            color: var(--muted);
            line-height: 1.5;
            max-width: 780px;
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 10px;
            align-items: center;
        }

        .hero-actions .button {
            min-width: 170px;
            text-align: center;
        }

        .panel,
        .summary,
        .table-card,
        .calendar-card,
        .login-card {
            background: linear-gradient(180deg, rgba(18, 21, 33, 0.98), rgba(13, 15, 23, 0.98));
            border: 1px solid var(--line);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
        }

        .panel {
            padding: 18px;
            margin-bottom: 18px;
        }

        .toolbar {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 14px;
            align-items: end;
        }

        .toolbar-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: end;
        }

        .toolbar-right {
            display: flex;
            justify-content: flex-end;
            align-items: end;
        }

        .field label {
            display: block;
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 6px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .7px;
        }

        input[type="date"],
        input[type="text"],
        input[type="password"],
        textarea {
            width: 100%;
            background: #0c0f18;
            color: white;
            border: 1px solid rgba(151, 116, 255, 0.18);
            border-radius: 12px;
            padding: 12px 14px;
            outline: none;
        }

        input:focus,
        textarea:focus {
            border-color: rgba(126, 234, 87, 0.65);
            box-shadow: 0 0 0 4px rgba(126, 234, 87, 0.10);
        }

        .button,
        button {
            border: none;
            border-radius: 14px;
            padding: 12px 16px;
            cursor: pointer;
            font-weight: 800;
            color: white;
            background: linear-gradient(135deg, var(--purple), var(--purple-2));
            box-shadow: 0 12px 30px rgba(95, 35, 203, 0.35);
        }

        .button:hover,
        button:hover {
            transform: translateY(-1px);
        }

        .button-green {
            background: linear-gradient(135deg, var(--green), var(--green-dark));
            color: #07110a;
            box-shadow: 0 12px 30px rgba(77, 198, 43, 0.24);
        }

        .button-dark {
            background: linear-gradient(135deg, #1d2233, #10131d);
            color: #eef2ff;
            border: 1px solid rgba(151, 116, 255, 0.16);
            box-shadow: none;
        }

        .summary {
            padding: 18px;
            margin-bottom: 18px;
        }

        .summary-header {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .summary-title {
            font-size: 18px;
            font-weight: 800;
        }

        .summary-subtitle {
            color: var(--muted);
            font-size: 14px;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
            gap: 12px;
        }

        .metric {
            background:
                linear-gradient(180deg, rgba(139, 77, 255, 0.08), rgba(255, 255, 255, 0.02));
            border: 1px solid rgba(151, 116, 255, 0.14);
            border-radius: 16px;
            padding: 14px;
        }

        .metric-label {
            color: var(--muted);
            font-size: 12px;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: .7px;
        }

        .metric strong {
            display: block;
            margin-top: 8px;
            font-size: 28px;
        }

        .flash {
            border-radius: 16px;
            padding: 14px 16px;
            margin-bottom: 18px;
            font-weight: 700;
            border: 1px solid transparent;
        }

        .flash.success {
            background: rgba(126, 234, 87, 0.10);
            border-color: rgba(126, 234, 87, 0.24);
            color: #d8ffd0;
        }

        .flash.info {
            background: rgba(139, 77, 255, 0.12);
            border-color: rgba(139, 77, 255, 0.26);
            color: #e6daff;
        }

        .table-card {
            overflow: hidden;
        }

        .table-head {
            padding: 18px;
            border-bottom: 1px solid var(--line);
            display: flex;
            justify-content: space-between;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .table-head h2 {
            margin: 0;
            font-size: 20px;
        }

        .table-head p {
            margin: 6px 0 0;
            color: var(--muted);
            font-size: 14px;
        }

        .table-wrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 1100px;
        }

        th,
        td {
            padding: 14px 16px;
            border-bottom: 1px solid rgba(151, 116, 255, 0.10);
            vertical-align: middle;
            text-align: left;
        }

        thead th {
            color: #cfd6f7;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .7px;
            background: rgba(255, 255, 255, 0.02);
        }

        tbody tr:hover {
            background: rgba(139, 77, 255, 0.05);
        }

        .member-name {
            font-weight: 800;
            font-size: 15px;
        }

        .member-id {
            color: var(--muted);
            font-size: 12px;
            margin-top: 4px;
        }

        .role-pill {
            display: inline-flex;
            align-items: center;
            padding: 6px 10px;
            border-radius: 999px;
            background: rgba(139, 77, 255, 0.14);
            color: #ece3ff;
            border: 1px solid rgba(139, 77, 255, 0.22);
            margin: 4px 6px 0 0;
            font-size: 12px;
            font-weight: 700;
        }

        .slot-grid {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .slot-pill {
            position: relative;
        }

        .slot-pill input {
            position: absolute;
            opacity: 0;
            inset: 0;
            cursor: pointer;
        }

        .slot-pill span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 78px;
            padding: 10px 12px;
            border-radius: 12px;
            border: 1px solid rgba(151, 116, 255, 0.20);
            background: #0b0e17;
            color: #dce3ff;
            font-weight: 800;
            transition: .18s ease;
        }

        .slot-pill input:checked+span {
            background: linear-gradient(135deg, rgba(126, 234, 87, 0.24), rgba(77, 198, 43, 0.14));
            border-color: rgba(126, 234, 87, 0.44);
            color: #eaffdf;
            box-shadow: inset 0 0 0 1px rgba(126, 234, 87, 0.12);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            padding: 8px 12px;
            font-weight: 800;
            font-size: 12px;
        }

        .status-presente {
            background: rgba(126, 234, 87, 0.15);
            color: #dfffd3;
            border: 1px solid rgba(126, 234, 87, 0.30);
        }

        .status-parziale {
            background: rgba(255, 209, 102, 0.12);
            color: #fff0bf;
            border: 1px solid rgba(255, 209, 102, 0.28);
        }

        .status-assente {
            background: rgba(255, 107, 129, 0.11);
            color: #ffd7dd;
            border: 1px solid rgba(255, 107, 129, 0.24);
        }

        .savebar {
            position: sticky;
            bottom: 16px;
            margin-top: 18px;
            background: rgba(9, 10, 16, 0.92);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(151, 116, 255, 0.18);
            border-radius: 18px;
            padding: 14px 16px;
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: center;
            box-shadow: var(--shadow);
        }

        .savebar-text {
            color: var(--muted);
            font-size: 14px;
        }

        .savebar-text strong {
            color: white;
        }

        .save-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .tiny {
            font-size: 12px;
            color: var(--muted);
        }

        @media (max-width: 1100px) {
            .hero-grid {
                grid-template-columns: 1fr;
            }

            .hero-actions {
                justify-content: flex-start;
            }

            .toolbar {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            body {
                padding: 14px;
            }

            .hero {
                padding: 20px;
            }

            .hero-grid {
                grid-template-columns: 1fr;
                gap: 16px;
            }

            .logo-wrap {
                width: 200px;
                height: 200px;
                border-radius: 30px;
            }

            .logo-wrap img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                padding: 4px;
            }

            .hero h1 {
                font-size: 28px;
                line-height: 1.08;
            }

            .hero p {
                font-size: 15px;
                line-height: 1.55;
            }

            .hero-actions {
                justify-content: stretch;
                width: 100%;
            }

            .hero-actions .button {
                width: 100%;
                min-width: 0;
            }

            .toolbar {
                grid-template-columns: 1fr;
            }

            .toolbar-group {
                flex-direction: column;
                align-items: stretch;
            }

            .toolbar-group .field,
            .toolbar-group button,
            .toolbar-right,
            .toolbar-right form,
            .toolbar-right button {
                width: 100%;
            }

            .savebar {
                flex-direction: column;
                align-items: stretch;
            }

            .save-actions {
                width: 100%;
            }

            .save-actions button,
            .save-actions a {
                width: 100%;
                text-align: center;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="hero">
            <div class="hero-grid">
                <div class="logo-wrap">
                    <img src="/assets/evergreen-logo.png" alt="EverGreen logo" onerror="this.style.display='none'">
                </div>

                <div>
                    <div class="eyebrow">EverGreen Competitive Control Panel</div>
                    <h1>Presenze roster — <%= date %>
                    </h1>
                    <p>
                        Pannello rapido per il team competitivo EverGreen.
                        Seleziona le fasce su più player e salva tutto con un solo click.
                    </p>
                </div>

                <div class="hero-actions">
                    <a class="button button-dark" href="/calendario">Calendario</a>
                    <% if (webBaseUrl) { %>
                        <a class="button button-dark" href="<%= webBaseUrl %>/presenze?date=<%= date %>"
                            target="_blank">Apri URL pubblico</a>
                        <% } %>
                            <a class="button button-dark" href="/logout">Logout</a>
                </div>
            </div>
        </div>

        <% if (saved) { %>
            <div class="flash success">✅ Modifiche salvate correttamente.</div>
            <% } %>

                <% if (syncCount) { %>
                    <div class="flash info">🔄 Roster sincronizzato. Membri trovati: <strong>
                            <%= syncCount %>
                        </strong></div>
                    <% } %>

                        <div class="panel">
                            <div class="toolbar">
                                <div>
                                    <form method="get" action="/presenze" class="toolbar-group">
                                        <div class="field">
                                            <label for="date">Giorno</label>
                                            <input id="date" type="date" name="date" value="<%= date %>" />
                                        </div>
                                        <button type="submit">Apri giorno</button>
                                    </form>

                                    <div class="tiny" style="margin-top: 14px;">
                                        <% if (attendanceChannel) { %>
                                            Canale Discord configurato
                                            <% } else { %>
                                                Nessun canale Discord configurato per la pubblicazione.
                                                <% } %>
                                    </div>
                                </div>

                                <div class="toolbar-right">
                                    <form method="post" action="/sync-roster">
                                        <button class="button-dark" type="submit">Sincronizza roster</button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="summary">
                            <div class="summary-header">
                                <div>
                                    <div class="summary-title">Quadro generale giornata</div>
                                    <div class="summary-subtitle">Visuale rapida del roster competitivo EverGreen</div>
                                </div>
                            </div>

                            <div class="summary-grid">
                                <div class="metric">
                                    <div class="metric-label">Totale roster</div>
                                    <strong>
                                        <%= dayView.summary.totalMembers %>
                                    </strong>
                                </div>
                                <div class="metric">
                                    <div class="metric-label">Presenti almeno una fascia</div>
                                    <strong>
                                        <%= dayView.summary.anyPresenceCount %>
                                    </strong>
                                </div>
                                <div class="metric">
                                    <div class="metric-label">Full presence</div>
                                    <strong>
                                        <%= dayView.summary.fullPresenceCount %>
                                    </strong>
                                </div>
                                <div class="metric">
                                    <div class="metric-label">Assenti</div>
                                    <strong>
                                        <%= dayView.summary.absentCount %>
                                    </strong>
                                </div>
                                <div class="metric">
                                    <div class="metric-label">21-22</div>
                                    <strong>
                                        <%= dayView.summary.slot21Count %>
                                    </strong>
                                </div>
                                <div class="metric">
                                    <div class="metric-label">22-23</div>
                                    <strong>
                                        <%= dayView.summary.slot22Count %>
                                    </strong>
                                </div>
                                <div class="metric">
                                    <div class="metric-label">23-00</div>
                                    <strong>
                                        <%= dayView.summary.slot23Count %>
                                    </strong>
                                </div>
                            </div>
                        </div>

                        <form id="bulk-save-form" method="post" action="/presenze/<%= date %>/save-all">
                            <div class="table-card">
                                <div class="table-head">
                                    <div>
                                        <h2>Roster del giorno</h2>
                                        <p>Gestisci tutte le disponibilità da una schermata unica.</p>
                                    </div>
                                    <div class="tiny">Player mostrati: <strong>
                                            <%= dayView.entries.length %>
                                        </strong></div>
                                </div>

                                <div class="table-wrap">
                                    <table>
                                        <thead>
                                            <tr>
                                                <th>Membro</th>
                                                <th>Ruoli</th>
                                                <th>21-22</th>
                                                <th>22-23</th>
                                                <th>23-00</th>
                                                <th>Nota</th>
                                                <th>Stato attuale</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% for (const entry of dayView.entries) { %>
                                                <tr id="member-<%= entry.discord_user_id %>">
                                                    <td>
                                                        <div class="member-name">
                                                            <%= entry.label %>
                                                        </div>
                                                        <div class="member-id">
                                                            <%= entry.discord_user_id %>
                                                        </div>
                                                    </td>

                                                    <td>
                                                        <% for (const role of entry.tracked_roles) { %>
                                                            <span class="role-pill">
                                                                <%= role.roleName %>
                                                            </span>
                                                            <% } %>
                                                    </td>

                                                    <td>
                                                        <label class="slot-pill">
                                                            <input class="track-change" type="checkbox"
                                                                name="members[<%= entry.discord_user_id %>][slot_21_22]"
                                                                value="1" <%=Number(entry.slot_21_22)===1 ? "checked"
                                                                : "" %> />
                                                            <span>21-22</span>
                                                        </label>
                                                    </td>

                                                    <td>
                                                        <label class="slot-pill">
                                                            <input class="track-change" type="checkbox"
                                                                name="members[<%= entry.discord_user_id %>][slot_22_23]"
                                                                value="1" <%=Number(entry.slot_22_23)===1 ? "checked"
                                                                : "" %> />
                                                            <span>22-23</span>
                                                        </label>
                                                    </td>

                                                    <td>
                                                        <label class="slot-pill">
                                                            <input class="track-change" type="checkbox"
                                                                name="members[<%= entry.discord_user_id %>][slot_23_00]"
                                                                value="1" <%=Number(entry.slot_23_00)===1 ? "checked"
                                                                : "" %> />
                                                            <span>23-00</span>
                                                        </label>
                                                    </td>

                                                    <td>
                                                        <input class="track-change" type="text"
                                                            name="members[<%= entry.discord_user_id %>][note]"
                                                            value="<%= entry.notes || '' %>"
                                                            placeholder="Nota facoltativa" />
                                                    </td>

                                                    <td>
                                                        <% const statusClass=entry.status==="Presente"
                                                            ? "status-presente" : entry.status==="Parziale"
                                                            ? "status-parziale" : "status-assente" ; %>
                                                            <span class="status-badge <%= statusClass %>">
                                                                <%= entry.status %>
                                                            </span>
                                                    </td>
                                                </tr>
                                                <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="savebar">
                                <div class="savebar-text">
                                    <strong id="dirty-text">Nessuna modifica non salvata</strong><br />
                                    Se cambi più presenze, ti basta un solo click su <strong>Salva tutto</strong>.
                                </div>

                                <div class="save-actions">
                                    <button type="submit" class="button-green">Salva tutto</button>
                                </div>
                            </div>
                        </form>
    </div>

    <script>
        (function () {
            const form = document.getElementById("bulk-save-form");
            const dirtyText = document.getElementById("dirty-text");
            let dirty = false;

            function setDirty(value) {
                dirty = value;
                dirtyText.textContent = dirty
                    ? "Ci sono modifiche non salvate"
                    : "Nessuna modifica non salvata";
            }

            document.querySelectorAll(".track-change").forEach((el) => {
                el.addEventListener("change", () => setDirty(true));
                el.addEventListener("input", () => setDirty(true));
            });

            form.addEventListener("submit", () => {
                setDirty(false);
            });

            window.addEventListener("beforeunload", (event) => {
                if (!dirty) return;
                event.preventDefault();
                event.returnValue = "";
            });
        })();
    </script>
</body>

</html>
