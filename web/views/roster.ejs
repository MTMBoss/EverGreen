<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/assets/hub.css" />
</head>

<body class="hub-body">
    <%- include("partials/nav", { currentSection }) %>

    <section class="hub-page-header">
        <div>
            <h1>Roster Tracciato</h1>
            <p>
                Questa vista usa i membri reali sincronizzati dal bot e i ruoli che stai tracciando su Discord.
                È la controparte concreta della sezione roster del layout Replit.
            </p>
            <div class="hub-chip">
                <span class="hub-chip-dot"></span>
                Membri attivi: <%= roster.length %>
            </div>
        </div>

        <div class="hub-actions">
            <a class="hub-button secondary" href="/presenze">Apri presenze</a>
            <a class="hub-button secondary" href="/calendario">Apri calendario</a>
            <a class="hub-button danger" href="/logout">Logout</a>
        </div>
    </section>

    <section class="hub-roster-grid">
        <% for (const member of roster) { %>
            <article class="hub-roster-card">
                <div class="hub-roster-body">
                    <div class="hub-roster-top">
                        <div class="hub-avatar">
                            <%= (member.label || "?").slice(0, 2).toUpperCase() %>
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <div class="hub-member-name"><%= member.label %></div>
                            <div class="hub-member-sub"><%= member.discord_user_id %></div>
                            <div style="margin-top: 10px;">
                                <% if (member.tracked_roles.length) { %>
                                    <% for (const role of member.tracked_roles) { %>
                                        <span class="hub-role-pill"><%= role.roleName %></span>
                                    <% } %>
                                <% } else { %>
                                    <span class="hub-muted">Nessun ruolo tracciato</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="hub-roster-footer">
                    <div>
                        <div class="hub-stat-label">Nickname Discord</div>
                        <div class="hub-stat-value"><%= member.nickname || "-" %></div>
                    </div>
                    <div>
                        <div class="hub-stat-label">Display Name</div>
                        <div class="hub-stat-value"><%= member.display_name || "-" %></div>
                    </div>
                </div>
            </article>
        <% } %>
    </section>

    </main>
</div>
</body>

</html>
