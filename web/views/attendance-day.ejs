<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= pageTitle %>
    </title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #0f172a;
            color: #e5e7eb;
            margin: 0;
            padding: 24px;
        }

        a {
            color: #93c5fd;
            text-decoration: none;
        }

        .topbar,
        .summary,
        .card {
            background: #111827;
            border: 1px solid #1f2937;
            border-radius: 14px;
            padding: 18px;
            margin-bottom: 18px;
        }

        .topbar {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            justify-content: space-between;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 12px;
        }

        .metric {
            background: #1f2937;
            border-radius: 12px;
            padding: 12px;
        }

        .metric strong {
            display: block;
            font-size: 24px;
            margin-top: 6px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            border-bottom: 1px solid #1f2937;
            padding: 12px 8px;
            vertical-align: middle;
            text-align: left;
        }

        th {
            color: #cbd5e1;
        }

        .row-form {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
        }

        .row-form input[type="text"] {
            padding: 8px;
            border-radius: 8px;
            border: 1px solid #374151;
            background: #0f172a;
            color: white;
            min-width: 180px;
        }

        .button,
        button {
            background: #4f46e5;
            color: white;
            border: none;
            padding: 10px 14px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 700;
        }

        .ghost {
            background: #374151;
        }

        .success {
            color: #86efac;
            font-weight: 700;
        }

        .role-pill {
            display: inline-block;
            background: #1e3a8a;
            color: #dbeafe;
            border-radius: 999px;
            padding: 4px 10px;
            margin-right: 6px;
            font-size: 12px;
        }

        .status {
            font-weight: 700;
        }

        .checkbox-wrap {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .checkbox-wrap label {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        @media (max-width: 960px) {

            table,
            thead,
            tbody,
            th,
            td,
            tr {
                display: block;
            }

            thead {
                display: none;
            }

            tr {
                margin-bottom: 16px;
                border: 1px solid #1f2937;
                border-radius: 12px;
                padding: 12px;
                background: #111827;
            }

            td {
                border: none;
                padding: 8px 0;
            }
        }
    </style>
</head>

<body>
    <div class="topbar">
        <div>
            <h1 style="margin: 0 0 8px">Presenze <%= date %>
            </h1>
            <div>
                <a href="/calendario">Vai al calendario</a>
                <% if (webBaseUrl) { %>
                    | <a href="<%= webBaseUrl %>/presenze?date=<%= date %>" target="_blank">Apri URL pubblico</a>
                    <% } %>
                        | <a href="/logout">Logout</a>
            </div>
        </div>
        <div class="actions">
            <form method="get" action="/presenze">
                <input type="date" name="date" value="<%= date %>" />
                <button type="submit">Apri giorno</button>
            </form>
            <form method="post" action="/sync-roster">
                <button class="ghost" type="submit">Sincronizza roster</button>
            </form>
        </div>
    </div>

    <% if (saved) { %>
        <div class="summary success">✅ Dati salvati correttamente.</div>
        <% } %>

            <div class="summary">
                <div class="summary-grid">
                    <div class="metric">Totale roster<strong>
                            <%= dayView.summary.totalMembers %>
                        </strong></div>
                    <div class="metric">Presenti almeno una fascia<strong>
                            <%= dayView.summary.anyPresenceCount %>
                        </strong></div>
                    <div class="metric">Full presence<strong>
                            <%= dayView.summary.fullPresenceCount %>
                        </strong></div>
                    <div class="metric">Assenti<strong>
                            <%= dayView.summary.absentCount %>
                        </strong></div>
                    <div class="metric">21-22<strong>
                            <%= dayView.summary.slot21Count %>
                        </strong></div>
                    <div class="metric">22-23<strong>
                            <%= dayView.summary.slot22Count %>
                        </strong></div>
                    <div class="metric">23-00<strong>
                            <%= dayView.summary.slot23Count %>
                        </strong></div>
                </div>
                <% if (attendanceChannel) { %>
                    <p style="margin-top: 16px">Canale pubblicazione Discord: <strong>#<%= attendanceChannel %></strong>
                    </p>
                    <% } %>
            </div>

            <div class="card">
                <table>
                    <thead>
                        <tr>
                            <th>Membro</th>
                            <th>Ruoli</th>
                            <th>Fasce orarie</th>
                            <th>Nota</th>
                            <th>Stato</th>
                            <th>Azione</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (const entry of dayView.entries) { %>
                            <tr id="member-<%= entry.discord_user_id %>">
                                <td>
                                    <strong>
                                        <%= entry.label %>
                                    </strong><br />
                                    <small>
                                        <%= entry.discord_user_id %>
                                    </small>
                                </td>
                                <td>
                                    <% for (const role of entry.tracked_roles) { %>
                                        <span class="role-pill">
                                            <%= role.roleName %>
                                        </span>
                                        <% } %>
                                </td>
                                <td>
                                    <form class="row-form" method="post"
                                        action="/presenze/<%= date %>/<%= entry.discord_user_id %>">
                                        <div class="checkbox-wrap">
                                            <label>
                                                <input type="checkbox" name="slot_21_22" value="1"
                                                    <%=Number(entry.slot_21_22)===1 ? 'checked' : '' %> />
                                                21-22
                                            </label>
                                            <label>
                                                <input type="checkbox" name="slot_22_23" value="1"
                                                    <%=Number(entry.slot_22_23)===1 ? 'checked' : '' %> />
                                                22-23
                                            </label>
                                            <label>
                                                <input type="checkbox" name="slot_23_00" value="1"
                                                    <%=Number(entry.slot_23_00)===1 ? 'checked' : '' %> />
                                                23-00
                                            </label>
                                        </div>
                                </td>
                                <td>
                                    <input type="text" name="note" value="<%= entry.notes || '' %>"
                                        placeholder="Nota facoltativa" />
                                </td>
                                <td class="status">
                                    <%= entry.status %>
                                </td>
                                <td>
                                    <button type="submit">Salva</button>
                                    </form>
                                </td>
                            </tr>
                            <% } %>
                    </tbody>
                </table>
            </div>
</body>

</html>
